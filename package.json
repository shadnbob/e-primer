{
  "name": "e-prime-bias-detector",
  "version": "2.0.0",
  "description": "E-Prime Bias Detector - Chrome/Firefox Extension",
  "scripts": {
    "build": "node build.js",
    "build:chrome": "node build.js --target=chrome",
    "build:firefox": "node build.js --target=firefox",
    "build:all": "node build.js --target=all",
    "watch": "node build.js --watch",
    "watch:chrome": "node build.js --watch --target=chrome",
    "dev": "npm run watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "esbuild": "^0.19.0",
    "jsdom": "^26.1.0",
    "vitest": "^3.2.4"
  },
  "private": true
}
