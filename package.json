{
  "name": "e-prime-bias-detector",
  "version": "2.0.0",
  "description": "E-Prime Bias Detector - Chrome Extension",
  "scripts": {
    "build": "node build.js",
    "watch": "node build.js --watch",
    "dev": "npm run watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:jest": "jest",
    "test:jest-coverage": "jest --coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "c8": "^10.1.3",
    "esbuild": "^0.19.0",
    "jest": "^29.7.0",
    "jsdom": "^26.1.0",
    "vitest": "^3.2.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/*.test.js"
    ]
  },
  "private": true
}
